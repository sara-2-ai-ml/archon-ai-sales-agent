# ============================================================
# ARCHON. — Environment Variables
# Copy this file to .env.local and fill in your API keys
# cp .env.example .env.local
# ============================================================


# ------------------------------------------------------------
# DATABASE — Turso (libSQL) — required at runtime
# Create a database at https://turso.tech
# ------------------------------------------------------------
TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Used only by Prisma CLI (db push / migrate) — local SQLite file
DATABASE_URL="file:./dev.db"


# ------------------------------------------------------------
# ANTHROPIC (Claude AI)
# Used by: Agent 1 (Lead Finder), Agent 2 (Researcher),
#          Agent 3 (Email Writer), Agent 5 (Reporter)
# Get your key at: https://console.anthropic.com
# ------------------------------------------------------------
ANTHROPIC_API_KEY=


# ------------------------------------------------------------
# TAVILY (Web Search)
# Used by: Agent 1 (Lead Finder) — searches for real companies
# Free tier available at: https://tavily.com
# Without this key, the system falls back to AI-generated leads
# ------------------------------------------------------------
TAVILY_API_KEY=


# ------------------------------------------------------------
# RESEND (Email Sending)
# Used by: Agent 4 (Outreach) — sends cold emails
# Free tier available at: https://resend.com
# Without this key, email sends are simulated (demo mode)
# ------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=


# ------------------------------------------------------------
# FIRECRAWL (Web Scraping)  — Optional
# Used by: Agent 2 (Researcher) — scrapes company websites
# Free tier available at: https://firecrawl.dev
# Without this key, research falls back to AI-only mode
# ------------------------------------------------------------
FIRECRAWL_API_KEY=


# ------------------------------------------------------------
# APOLLO.IO (Lead Enrichment)  — Optional
# Used for: enriching lead data with contact information
# Free tier available at: https://apollo.io
# ------------------------------------------------------------
APOLLO_API_KEY=


# ------------------------------------------------------------
# GOOGLE GEMINI  — Optional
# Alternative AI model provider
# Get your key at: https://aistudio.google.com
# ------------------------------------------------------------
GEMINI_API_KEY=
